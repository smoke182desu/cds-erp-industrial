{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the Gravia catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "specifications": { "type": "string", "description": "Technical specifications." },
        "imageUrl": { "type": "string", "description": "URL of the product image." }
      },
      "required": ["name", "category"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "description": "The role of the user (e.g., admin, user)." }
      },
      "required": ["role"]
    },
    "Project": {
      "title": "Project",
      "description": "A design project.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the project." },
        "data": { "type": "object", "description": "The project data." },
        "userId": { "type": "string", "description": "The ID of the user who owns the project." },
        "updated_at": { "type": "number", "description": "The timestamp of the last update." }
      },
      "required": ["name", "userId", "updated_at"]
    },
    "Client": {
      "title": "Client",
      "description": "A customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client name." },
        "email": { "type": "string", "description": "Client email." },
        "phone": { "type": "string", "description": "Client phone." },
        "document": { "type": "string", "description": "CPF/CNPJ." },
        "address": { "type": "string", "description": "Address." }
      },
      "required": ["name", "email"]
    },
    "Proposal": {
      "title": "Proposal",
      "description": "A commercial proposal.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "Reference to Client." },
        "projectId": { "type": "string", "description": "Reference to Project." },
        "totalValue": { "type": "number", "description": "Total value." },
        "status": { "type": "string", "description": "Proposal status (draft, sent, signed)." },
        "signatureData": { "type": "string", "description": "Base64 signature image." },
        "createdAt": { "type": "number", "description": "Timestamp." }
      },
      "required": ["clientId", "projectId", "totalValue", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Collection of Gravia products."
    },
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Collection of users."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "Collection of user projects."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "Client" },
      "description": "Collection of clients."
    },
    "/proposals/{proposalId}": {
      "schema": { "$ref": "Proposal" },
      "description": "Collection of proposals."
    }
  }
}
