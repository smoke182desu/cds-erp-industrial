{
  "rewrites": [
    {
      "source": "/pncp-api/(.*)",
      "destination": "/api/pncp?path=$1"
    },
    {
      "source": "/api/clientes",
      "destination": "/api/data?resource=clientes"
    },
    {
      "source": "/api/config",
      "destination": "/api/data?resource=config"
    },
    {
      "source": "/api/projects",
      "destination": "/api/data?resource=projects"
    },
    {
      "source": "/api/calculadora",
      "destination": "/api/data?resource=calculadora"
    },
    {
      "source": "/api/fotos",
      "destination": "/api/fotos"
    },
    {
      "source": "/api/image-proxy",
      "destination": "/api/data?resource=image-proxy"
    },
    {
      "source": "/api/extension-posts",
      "destination": "/api/data?resource=extension-posts"
    },
    {
      "source": "/api/social-publish",
      "destination": "/api/data?resource=social-publish"
    }
  ]
}
